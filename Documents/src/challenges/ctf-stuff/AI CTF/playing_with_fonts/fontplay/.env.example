# Add values and rename this file to .env

# This should be OpenAI project key with `audio` permission
OPENAI_API_KEY=

# Just a few random bytes for security
SECRET_KEY=
CSRF_SECRET_KEY=

# reCAPTCHA v2 private and public key. Use debug mode to skip captcha
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SITE_KEY=
